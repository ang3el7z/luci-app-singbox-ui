{
    "luci-app-singbox-ui": {
        "description": "Singbox-UI management access",
        "read": {
            "file": {
                "/etc/init.d/sing-box": ["exec"],
                "/etc/init.d/singbox-ui-autoupdater-service": ["exec"],
                "/etc/init.d/singbox-ui-memdoc-service": ["exec"],
                "/etc/init.d/singbox-ui-health-autoupdater-service": ["exec"],
                "/etc/init.d/*": ["read"],
                "/etc/nftables.d/*": ["read"],
                "/etc/sing-box/*": ["read"],
                "/usr/bin/singbox-ui/*": ["exec"],
                "/usr/bin/sing-box": ["exec"],
                "/usr/sbin/nft": ["exec"],
                "/bin/opkg": ["exec"],
                "/usr/bin/apk": ["exec"],
                "/sbin/uci": ["exec"],
                "/tmp/*": ["read"]
            },
            "uci": ["singbox-ui"]
        },
        "write": {
            "file": {
                "/etc/sing-box/*": ["write"],
                "/sbin/uci": ["exec"],
                "/tmp/*": ["write", "exec"]
            },
            "uci": ["singbox-ui"]
        }
    }
}
