#!/bin/sh

readonly UCI_OPTION='autoupdater_service_state'
readonly SERVICE_NAME='singbox-ui-autoupdater-service'
readonly TARGET_FILE='/etc/sing-box/config.json'
readonly URL_FILE='/etc/sing-box/url_config.json'
readonly INTERVAL=3600

check_uci() {
	local enabled
	enabled="$(uci get singbox-ui.main."$UCI_OPTION" 2>/dev/null)" || enabled='0'
	if [ "$enabled" != '1' ]; then
		logger -t "$SERVICE_NAME" "disabled via UCI, stopping"
		/etc/init.d/"$SERVICE_NAME" stop
		exit 0
	fi
}

wait_for_singbox() {
	while ! pgrep -x sing-box >/dev/null 2>&1; do
		logger -t "$SERVICE_NAME" "waiting for sing-box..."
		sleep 30
	done
}

run_update() {
	/usr/bin/singbox-ui/singbox-ui-updater "$URL_FILE" "$TARGET_FILE"
}

logger -t "$SERVICE_NAME" "starting"
check_uci
wait_for_singbox

while true; do
	logger -t "$SERVICE_NAME" "running updater"
	run_update
	code=$?
	case $code in
		0) logger -t "$SERVICE_NAME" "config updated, reloading sing-box"
		   /etc/init.d/sing-box reload ;;
		2) logger -t "$SERVICE_NAME" "no changes in config" ;;
		*) logger -t "$SERVICE_NAME" "updater failed (exit $code)" ;;
	esac
	sleep "$INTERVAL"
	wait_for_singbox
done
