#!/bin/sh

readonly UCI_OPTION='health_autoupdater_service_state'
readonly SERVICE_NAME='singbox-ui-health-autoupdater-service'
readonly AUTOUPDATER_SERVICE='singbox-ui-autoupdater-service'
readonly TARGET_FILE='/etc/sing-box/config.json'
readonly URL_FILE='/etc/sing-box/url_config.json'
readonly ERROR_FLAG='/tmp/singbox-ui-health-error.flag'
readonly INTERVAL=90
readonly CHECKS_TO_UPDATE=60
readonly MAX_FAILS=2

check_uci() {
	local enabled
	enabled="$(uci get singbox-ui.main."$UCI_OPTION" 2>/dev/null)" || enabled='0'
	if [ "$enabled" != '1' ]; then
		logger -t "$SERVICE_NAME" "disabled via UCI, stopping"
		/etc/init.d/"$SERVICE_NAME" stop
		exit 0
	fi
}

check_autoupdater_conflict() {
	if pgrep -f "$AUTOUPDATER_SERVICE" >/dev/null 2>&1; then
		logger -t "$SERVICE_NAME" "$AUTOUPDATER_SERVICE is running, stopping $SERVICE_NAME"
		/etc/init.d/"$SERVICE_NAME" stop
		exit 0
	fi
}

wait_for_singbox() {
	while ! pgrep -x sing-box >/dev/null 2>&1; do
		logger -t "$SERVICE_NAME" "waiting for sing-box..."
		sleep 30
	done
}

check_server() {
	local url code
	url="$(cat "$URL_FILE" 2>/dev/null)" || return 1
	[ -n "$url" ] || return 1
	code="$(curl -s -o /dev/null -w '%{http_code}' -m 5 "$url")"
	[ "$code" -ge 200 ] && [ "$code" -lt 400 ]
}

run_update() {
	/usr/bin/singbox-ui/singbox-ui-updater "$URL_FILE" "$TARGET_FILE"
}

logger -t "$SERVICE_NAME" "starting"
check_uci
check_autoupdater_conflict
wait_for_singbox

success_counter=0
fail_counter=0

while true; do
	if check_server; then
		success_counter=$((success_counter + 1))
		fail_counter=0
		logger -t "$SERVICE_NAME" "health ok (success: $success_counter / threshold: $CHECKS_TO_UPDATE)"

		if [ -f "$ERROR_FLAG" ]; then
			run_update
			code=$?
			if [ "$code" = 0 ] || [ "$code" = 2 ]; then
				logger -t "$SERVICE_NAME" "network restored, starting sing-box"
				/etc/init.d/sing-box start
				rm -f "$ERROR_FLAG"
				success_counter=0
			else
				logger -t "$SERVICE_NAME" "updater failed during recovery (exit $code)"
			fi
		elif [ "$success_counter" -ge "$CHECKS_TO_UPDATE" ]; then
			logger -t "$SERVICE_NAME" "running periodic update"
			run_update
			code=$?
			case $code in
				0) logger -t "$SERVICE_NAME" "config updated, reloading sing-box"
				   /etc/init.d/sing-box reload ;;
				2) logger -t "$SERVICE_NAME" "no changes in config" ;;
				*) logger -t "$SERVICE_NAME" "updater failed (exit $code)"
				   touch "$ERROR_FLAG" ;;
			esac
			success_counter=0
		fi
	else
		fail_counter=$((fail_counter + 1))
		success_counter=0
		logger -t "$SERVICE_NAME" "health failed (fail: $fail_counter / threshold: $MAX_FAILS)"

		if [ "$fail_counter" -ge "$MAX_FAILS" ] && [ ! -f "$ERROR_FLAG" ]; then
			logger -t "$SERVICE_NAME" "stopping sing-box after $fail_counter consecutive failures"
			/etc/init.d/sing-box stop
			touch "$ERROR_FLAG"
		fi
	fi

	sleep "$INTERVAL"
	wait_for_singbox
done
