#!/bin/sh
set -e

readonly MAX_FILESIZE='10485760'  # 10 MB hard limit on downloaded config
readonly CURL_TIMEOUT='30'

logger -t singbox-ui-updater "starting: $*"

[ $# -eq 2 ] || {
	echo "Usage: $0 <url-file> <target-file>" >&2
	exit 1
}

URL_FILE="$1"
TARGET_FILE="$2"

[ -r "$URL_FILE" ] || {
	logger -t singbox-ui-updater "URL file not found: $URL_FILE"
	echo "URL file not found" >&2
	exit 1
}

CONFIG_URL="$(cat "$URL_FILE")"
[ -n "$CONFIG_URL" ] || {
	logger -t singbox-ui-updater "empty URL in $URL_FILE"
	echo "Empty URL" >&2
	exit 1
}

command -v curl >/dev/null || {
	logger -t singbox-ui-updater "curl not found"
	echo "curl not installed" >&2
	exit 1
}

command -v jq >/dev/null || {
	logger -t singbox-ui-updater "jq not found"
	echo "jq not installed" >&2
	exit 1
}

TMP_RAW="${TARGET_FILE}.tmp.$$.dl"
TMP_FILE="${TARGET_FILE}.tmp.$$"

logger -t singbox-ui-updater "downloading from $CONFIG_URL"

curl -fsSL \
	--max-time     "$CURL_TIMEOUT" \
	--max-filesize "$MAX_FILESIZE" \
	"$CONFIG_URL" -o "$TMP_RAW" || {
	logger -t singbox-ui-updater "download failed from $CONFIG_URL"
	rm -f "$TMP_RAW"
	exit 1
}

jq . "$TMP_RAW" > "$TMP_FILE" || {
	logger -t singbox-ui-updater "invalid JSON received"
	rm -f "$TMP_RAW" "$TMP_FILE"
	exit 1
}

rm -f "$TMP_RAW"

if [ -f "$TARGET_FILE" ]; then
	old_hash="$(sha256sum "$TARGET_FILE" | cut -d' ' -f1)"
	new_hash="$(sha256sum "$TMP_FILE"    | cut -d' ' -f1)"
	if [ "$old_hash" = "$new_hash" ]; then
		logger -t singbox-ui-updater "no changes detected"
		rm -f "$TMP_FILE"
		exit 2
	fi
fi

mv "$TMP_FILE" "$TARGET_FILE"
logger -t singbox-ui-updater "config updated successfully"
echo "Success"
exit 0
