#!/bin/sh

readonly SERVICE_NAME='singbox-ui-memdoc-service'
readonly SINGBOX='/etc/init.d/sing-box'
readonly THRESHOLD=15000        # free RAM threshold in KB (15 MB)
readonly MIN_RESTART_INTERVAL=60
readonly CHECK_INTERVAL=10

last_restart=0

wait_for_singbox() {
	while ! pidof sing-box >/dev/null 2>&1; do
		logger -t "$SERVICE_NAME" "waiting for sing-box..."
		sleep 30
	done
}

logger -t "$SERVICE_NAME" "starting"
wait_for_singbox

while true; do
	free_mem="$(awk '/MemAvailable/ { print $2 }' /proc/meminfo)"
	now="$(date +%s)"

	if [ "$free_mem" -le "$THRESHOLD" ]; then
		elapsed=$((now - last_restart))
		if [ "$elapsed" -ge "$MIN_RESTART_INTERVAL" ]; then
			logger -t "$SERVICE_NAME" "low memory: ${free_mem}KB <= ${THRESHOLD}KB"
			if [ -x "$SINGBOX" ] && "$SINGBOX" status 2>/dev/null | grep -q 'running'; then
				logger -t "$SERVICE_NAME" "restarting sing-box"
				"$SINGBOX" restart
				last_restart="$now"
				sleep 60
			else
				logger -t "$SERVICE_NAME" "sing-box not running, skipping restart"
			fi
		else
			logger -t "$SERVICE_NAME" "memory low but cooldown active (${elapsed}s / ${MIN_RESTART_INTERVAL}s)"
		fi
	fi

	sleep "$CHECK_INTERVAL"
	wait_for_singbox
done
