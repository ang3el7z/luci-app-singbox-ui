#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

CORE_RUNNER="/usr/bin/simo/simo-core"

active_core() {
	uci -q get simo.main.core 2>/dev/null || echo "mihomo"
}

start_service() {
	local core
	core="$(active_core)"

	"$CORE_RUNNER" "$core" prepare || return 1

	procd_open_instance "$core"
	procd_set_param command "$CORE_RUNNER" "$core" run
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	"$CORE_RUNNER" "$(active_core)" cleanup >/dev/null 2>&1 || true
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "simo"
}

