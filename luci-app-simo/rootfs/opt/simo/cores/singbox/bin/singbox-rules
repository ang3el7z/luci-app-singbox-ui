#!/bin/sh
# Usage: singbox-rules <action>
# Actions:
#   enable-tun | disable-tun | enable-tproxy | disable-tproxy
#   start | stop | restart | validate_policy | repair_policy | full_cleanup
#   guard_start | guard_stop | guard_refresh

set -e
ACTION="${1:-unknown}"

NFT_RULE_FILE="/opt/simo/cores/singbox/tproxy.nft"
NFT_RULE_TEMPLATE="/usr/libexec/simo/cores/singbox/tproxy.nft"
SYSCTL_CONF_FILE="/etc/sysctl.d/99-singbox-tproxy.conf"
TUN_IFACE="singtun0"
GUARD_NFT_TABLE="simo_guard"
GUARD_FORWARD_CHAIN="SIMO_GUARD_FORWARD"
GUARD_OUTPUT_CHAIN="SIMO_GUARD_OUTPUT"

# ── UI helpers ────────────────────────────────────────────────────────────────

FG_ACCENT='\033[38;5;85m'
FG_SUCCESS='\033[38;5;41m'
FG_ERROR='\033[38;5;203m'
RESET='\033[0m'
INDENT='  '
ARROW='▸'
CHECK='✓'
CROSS='✗'

step()  { echo -e "${INDENT}${ARROW} ${FG_ACCENT}$1${RESET}"; }
done_() { echo -e "${INDENT}${CHECK} ${FG_SUCCESS}$1${RESET}"; }

on_exit() {
    rc="$?"
    [ "$rc" -eq 0 ] && return 0
    echo -e "${INDENT}${CROSS} ${FG_ERROR}singbox-rules failed (action: ${ACTION})${RESET}" >&2
}

trap on_exit EXIT

# ── network.proxy UCI ────────────────────────────────────────────────────────

configure_proxy() {
    uci set network.proxy=interface
    uci set network.proxy.proto="none"
    uci set network.proxy.device="$TUN_IFACE"
    uci set network.proxy.defaultroute="0"
    uci set network.proxy.delegate="0"
    uci set network.proxy.peerdns="0"
    uci set network.proxy.auto="1"
    uci commit network
}

remove_configure_proxy() {
    uci -q delete network.proxy
    uci commit network
}

# ── firewall zone/forwarding for tun ─────────────────────────────────────────

configure_firewall_tun() {
    if ! uci -q show firewall | grep -q "\.name='proxy'"; then
        uci add firewall zone      >/dev/null
        uci set firewall.@zone[-1].name="proxy"
        uci set firewall.@zone[-1].forward="REJECT"
        uci set firewall.@zone[-1].output="ACCEPT"
        uci set firewall.@zone[-1].input="ACCEPT"
        uci set firewall.@zone[-1].masq="1"
        uci set firewall.@zone[-1].mtu_fix="1"
        uci set firewall.@zone[-1].device="$TUN_IFACE"
        uci set firewall.@zone[-1].family="ipv4"
        uci add_list firewall.@zone[-1].network="$TUN_IFACE"
    fi
    if ! uci -q show firewall | grep -q "\.dest='proxy'"; then
        uci add firewall forwarding >/dev/null
        uci set firewall.@forwarding[-1].dest="proxy"
        uci set firewall.@forwarding[-1].src="lan"
        uci set firewall.@forwarding[-1].family="ipv4"
    fi
    uci commit firewall
}

remove_firewall_tun() {
    zone_id=$(uci -q show firewall | grep "\.name='proxy'" | sed "s/firewall\.@zone\[\([0-9]*\)\].*/\1/" || true)
    [ -n "$zone_id" ] && uci -q delete firewall.@zone["$zone_id"]

    fwd_id=$(uci -q show firewall | grep "\.dest='proxy'" | sed "s/firewall\.@forwarding\[\([0-9]*\)\].*/\1/" || true)
    [ -n "$fwd_id" ] && uci -q delete firewall.@forwarding["$fwd_id"]

    uci commit firewall
}

# ── nft rules ────────────────────────────────────────────────────────────────

install_nft_rule() {
    mkdir -p /opt/simo/cores/singbox
    [ -f "$NFT_RULE_FILE" ] || cp "$NFT_RULE_TEMPLATE" "$NFT_RULE_FILE"
    nft -f "$NFT_RULE_FILE"
}

uninstall_nft_rule() {
    nft delete table ip singbox 2>/dev/null || true
    rm -f "$NFT_RULE_FILE"
}

flush_tproxy_table() {
    nft delete table ip singbox 2>/dev/null || true
}

# ── tproxy firewall include ───────────────────────────────────────────────────

ensure_tproxy_firewall_include() {
    uci set firewall.singbox_tproxy=include
    uci set firewall.singbox_tproxy.type="nftables"
    uci set firewall.singbox_tproxy.path="$NFT_RULE_FILE"
    uci set firewall.singbox_tproxy.position="ruleset-prepend"
    uci -q delete firewall.singbox_tproxy.chain || true
    uci set firewall.singbox_tproxy.enabled="1"
    uci commit firewall
}

remove_tproxy_firewall_include() {
    uci -q delete firewall.singbox_tproxy
    uci commit firewall
}

# ── sysctl for tproxy ──────────────────────────────────────────────────────

install_sysctl_config() {
    for iface in /proc/sys/net/ipv4/conf/*/route_localnet; do
        echo 1 > "$iface" 2>/dev/null || true
    done

    mkdir -p /etc/sysctl.d
    cat > "$SYSCTL_CONF_FILE" << 'EOF'
net.ipv4.conf.all.route_localnet=1
net.ipv4.conf.default.route_localnet=1
EOF
    sysctl -p "$SYSCTL_CONF_FILE" >/dev/null 2>&1 || true
}

uninstall_sysctl_config() {
    for iface in /proc/sys/net/ipv4/conf/*/route_localnet; do
        echo 0 > "$iface" 2>/dev/null || true
    done

    rm -f "$SYSCTL_CONF_FILE"
}

# ── policy routing for tproxy ────────────────────────────────────────────────

setup_tproxy_routing() {
    ip rule add fwmark 1 table 100 2>/dev/null || true
    ip route add local 0.0.0.0/0 dev lo table 100 2>/dev/null || true

    uci set network.singbox_tproxy_rule=rule
    uci set network.singbox_tproxy_rule.mark='0x1'
    uci set network.singbox_tproxy_rule.lookup='100'
    uci set network.singbox_tproxy_rule.priority='100'

    uci set network.singbox_tproxy_route=route
    uci set network.singbox_tproxy_route.interface='loopback'
    uci set network.singbox_tproxy_route.target='0.0.0.0'
    uci set network.singbox_tproxy_route.netmask='0.0.0.0'
    uci set network.singbox_tproxy_route.table='100'
    uci set network.singbox_tproxy_route.type='local'

    uci commit network
}

cleanup_tproxy_routing() {
    ip rule del fwmark 1 table 100 2>/dev/null || true
    ip route flush table 100 2>/dev/null || true

    uci -q delete network.singbox_tproxy_rule
    uci -q delete network.singbox_tproxy_route
    uci commit network
}

validate_tproxy_policy() {
    ip rule show 2>/dev/null | grep -Eq 'fwmark (0x0*1|1)(/[0-9xa-fA-F]+)? .*lookup 100( |$)' || return 1
    ip route show table 100 2>/dev/null | grep -q 'local 0.0.0.0/0 dev lo' || return 1
}

repair_tproxy_policy() {
    setup_tproxy_routing
    validate_tproxy_policy
}

guard_enabled() {
    [ "$(uci -q get simo.main.internet_only 2>/dev/null)" = "1" ]
}

detect_wan_ifaces() {
    local configured
    configured="$(uci -q get simo.main.guard_wan_ifaces 2>/dev/null || true)"
    if [ -n "$configured" ]; then
        printf '%s\n' "$configured"
        return 0
    fi
    ip route show default 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i == "dev") print $(i + 1) }' | sort -u
}

apply_guard_rules() {
    local ifaces iface
    ifaces="$(detect_wan_ifaces)"
    [ -n "$ifaces" ] || return 0

    if command -v nft >/dev/null 2>&1; then
        nft delete table inet "$GUARD_NFT_TABLE" 2>/dev/null || true
        nft add table inet "$GUARD_NFT_TABLE"
        nft add chain inet "$GUARD_NFT_TABLE" forward '{ type filter hook forward priority 1; policy accept; }'
        nft add chain inet "$GUARD_NFT_TABLE" output '{ type filter hook output priority 1; policy accept; }'
        nft add rule inet "$GUARD_NFT_TABLE" forward iifname "$TUN_IFACE" accept 2>/dev/null || true
        nft add rule inet "$GUARD_NFT_TABLE" forward oifname "$TUN_IFACE" accept 2>/dev/null || true
        echo "$ifaces" | while IFS= read -r iface; do
            [ -n "$iface" ] || continue
            nft add rule inet "$GUARD_NFT_TABLE" forward oifname "$iface" drop comment "simo-guard" 2>/dev/null || true
            nft add rule inet "$GUARD_NFT_TABLE" output oifname "$iface" drop comment "simo-guard" 2>/dev/null || true
        done
        return 0
    fi

    if command -v iptables >/dev/null 2>&1; then
        iptables -N "$GUARD_FORWARD_CHAIN" 2>/dev/null || true
        iptables -N "$GUARD_OUTPUT_CHAIN" 2>/dev/null || true
        iptables -F "$GUARD_FORWARD_CHAIN" 2>/dev/null || true
        iptables -F "$GUARD_OUTPUT_CHAIN" 2>/dev/null || true
        iptables -C FORWARD -j "$GUARD_FORWARD_CHAIN" 2>/dev/null || iptables -A FORWARD -j "$GUARD_FORWARD_CHAIN"
        iptables -C OUTPUT -j "$GUARD_OUTPUT_CHAIN" 2>/dev/null || iptables -A OUTPUT -j "$GUARD_OUTPUT_CHAIN"
        iptables -A "$GUARD_FORWARD_CHAIN" -i "$TUN_IFACE" -j RETURN 2>/dev/null || true
        iptables -A "$GUARD_FORWARD_CHAIN" -o "$TUN_IFACE" -j RETURN 2>/dev/null || true
        echo "$ifaces" | while IFS= read -r iface; do
            [ -n "$iface" ] || continue
            iptables -A "$GUARD_FORWARD_CHAIN" -o "$iface" -j DROP 2>/dev/null || true
            iptables -A "$GUARD_OUTPUT_CHAIN" -o "$iface" -j DROP 2>/dev/null || true
        done
    fi
}

remove_guard_rules() {
    nft delete table inet "$GUARD_NFT_TABLE" 2>/dev/null || true
    if command -v iptables >/dev/null 2>&1; then
        while iptables -D FORWARD -j "$GUARD_FORWARD_CHAIN" 2>/dev/null; do :; done
        while iptables -D OUTPUT -j "$GUARD_OUTPUT_CHAIN" 2>/dev/null; do :; done
        iptables -F "$GUARD_FORWARD_CHAIN" 2>/dev/null || true
        iptables -X "$GUARD_FORWARD_CHAIN" 2>/dev/null || true
        iptables -F "$GUARD_OUTPUT_CHAIN" 2>/dev/null || true
        iptables -X "$GUARD_OUTPUT_CHAIN" 2>/dev/null || true
    fi
}

refresh_guard_rules() {
    if guard_enabled; then
        apply_guard_rules
    else
        remove_guard_rules
    fi
}

# ── service helpers ──────────────────────────────────────────────────────────

reload_firewall() {
    service firewall reload >/dev/null 2>&1
}

reload_network() {
    uci commit network
    /etc/init.d/network reload >/dev/null 2>&1
    ifup proxy 2>/dev/null || true
}

set_simo_mode() {
    uci set simo.main.mode="$1"
    uci commit simo
}

# ── actions ──────────────────────────────────────────────────────────────────

case "$1" in
    start)
        if guard_enabled; then
            step "Applying Simo guard..."
            apply_guard_rules
        else
            remove_guard_rules
        fi
        echo "ok"
        ;;
    stop)
        remove_guard_rules
        echo "ok"
        ;;
    restart)
        "$0" stop
        "$0" start
        ;;
    enable-tun)
        set_simo_mode "tun"
        step "Configuring network proxy interface..."
        configure_proxy
        step "Configuring firewall TUN zone..."
        configure_firewall_tun
        step "Reloading firewall..."
        reload_firewall
        step "Reloading network..."
        reload_network
        done_ "TUN mode enabled"
        refresh_guard_rules
        echo "ok"
        ;;
    disable-tun)
        step "Removing network proxy interface..."
        remove_configure_proxy
        step "Removing firewall TUN zone..."
        remove_firewall_tun
        step "Reloading firewall..."
        reload_firewall
        step "Reloading network..."
        reload_network
        done_ "TUN mode disabled"
        refresh_guard_rules
        echo "ok"
        ;;
    enable-tproxy)
        set_simo_mode "tproxy"
        step "Setting up policy routing..."
        setup_tproxy_routing
        step "Installing sysctl config..."
        install_sysctl_config
        step "Installing nftables rule..."
        install_nft_rule
        step "Configuring firewall include..."
        ensure_tproxy_firewall_include
        step "Flushing tproxy table for firewall reload..."
        flush_tproxy_table
        step "Reloading firewall..."
        reload_firewall
        done_ "TPROXY mode enabled"
        refresh_guard_rules
        echo "ok"
        ;;
    disable-tproxy)
        step "Removing firewall include..."
        remove_tproxy_firewall_include
        step "Reloading firewall..."
        reload_firewall
        step "Uninstalling nftables rule..."
        uninstall_nft_rule
        step "Cleaning up policy routing..."
        cleanup_tproxy_routing
        step "Uninstalling sysctl config..."
        uninstall_sysctl_config
        done_ "TPROXY mode disabled"
        refresh_guard_rules
        echo "ok"
        ;;
    validate_policy)
        validate_tproxy_policy
        echo "ok"
        ;;
    repair_policy)
        repair_tproxy_policy
        echo "ok"
        ;;
    guard_start)
        apply_guard_rules
        echo "ok"
        ;;
    guard_stop)
        remove_guard_rules
        echo "ok"
        ;;
    guard_refresh)
        refresh_guard_rules
        echo "ok"
        ;;
    full_cleanup)
        "$0" disable-tproxy >/dev/null 2>&1 || true
        "$0" disable-tun >/dev/null 2>&1 || true
        remove_guard_rules
        echo "ok"
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|enable-tun|disable-tun|enable-tproxy|disable-tproxy|validate_policy|repair_policy|guard_start|guard_stop|guard_refresh|full_cleanup}" >&2
        exit 1
        ;;
esac
